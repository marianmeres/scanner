{
  "name": "@marianmeres/scanner",
  "version": "1.0.1",
  "exports": {
    ".": "./src/mod.ts",
    "./stage": "./src/stage.ts"
  },
  "publish": {
    "exclude": [
      ".claude/",
      "tests/",
      "example/",
      "scripts/",
      "SPEC.md",
      ".env.example"
    ]
  },
  "tasks": {
    "test": "deno test",
    "test:watch": "deno test --watch",
    "npm:build": "deno run -A scripts/build-npm.ts",
    "npm:publish": "deno run -A scripts/build-npm.ts && cd ./.npm-dist && npm publish --access=public",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "publish": "deno publish && deno task npm:publish",
    "rp": "deno task release -y && deno task publish",
    "rpm": "deno task release minor -y && deno task publish",
    "build:example": "deno run -A jsr:@marianmeres/deno-build --esbuild --outdir example/dist && deno run -A jsr:@marianmeres/deno-build --esbuild --entry stage.ts --outfile stage.js --outdir example/dist",
    "build:example:watch": "deno run -A jsr:@marianmeres/deno-build --esbuild --outdir example/dist --watch",
    "example": "deno task build:example && deno run -A jsr:@std/http/file-server example"
  },
  "imports": {
    "@b-fuze/deno-dom": "jsr:@b-fuze/deno-dom@^0.1.56",
    "@marianmeres/clog": "jsr:@marianmeres/clog@^3.21.0",
    "@marianmeres/mediaperms": "jsr:@marianmeres/mediaperms@^1.1.1",
    "@marianmeres/store": "jsr:@marianmeres/store@^3.0.1",
    "@marianmeres/npmbuild": "jsr:@marianmeres/npmbuild@^1.16.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.6",
    "barcode-detector": "npm:barcode-detector@^3.2.1",
    "barcode-detector/ponyfill": "npm:barcode-detector@^3.2.1/ponyfill"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "deno.ns"
    ]
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4,
    "proseWrap": "preserve"
  }
}
